# Riot API key — obtain from https://developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Django secret key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

DEBUG=True

# Leave blank to use SQLite (default for local dev)
# Set to a PostgreSQL URL to use PostgreSQL, e.g.:
#   DATABASE_URL=postgresql://user:password@localhost:5432/tft_tracker
DATABASE_URL=
